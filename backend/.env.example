SECRET_KEY=your-secret-key-here

DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1,.localhost

# Multitenancy — single API domain; tenant resolved from JWT / login organization
SHOW_PUBLIC_IF_NO_TENANT_FOUND=True
SHARED_APP_DOMAIN=localhost



POSTGRES_DB=tickethub

POSTGRES_USER=tickethub

POSTGRES_PASSWORD=tickethub_password

POSTGRES_HOST=postgres

POSTGRES_PORT=5432



FRONTEND_URL=http://localhost:3000

BACKEND_PUBLIC_URL=http://localhost:8000

# GitHub OAuth — create at https://github.com/settings/developers
# Authorization callback URL: http://localhost:8000/api/public/integrations/github/callback/
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_SCOPES=read:user repo

WEBSITE_URL=https://technestinnovations.com.np



CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000



JWT_ACCESS_TOKEN_LIFETIME=60

JWT_REFRESH_TOKEN_LIFETIME=43200



ALLOW_PUBLIC_REGISTRATION=False



# --- Email (Technest-style) ---

# Dev default: console logs (set EMAIL_USE_SMTP_IN_DEBUG=True for real Gmail in dev)

# Or save emails to files: EMAIL_FILE_PATH=.emails-dev

# Production: set DEBUG=False and SMTP credentials below

EMAIL_USE_SMTP_IN_DEBUG=True

EMAIL_PORT=587

EMAIL_HOST_USER=you@gmail.com

EMAIL_HOST_PASSWORD=your-16-char-app-password

# Accept EMAIL_TLS (project .env) or Django's EMAIL_USE_TLS — both map to EMAIL_USE_TLS
EMAIL_TLS=true
# EMAIL_USE_TLS=true

DEFAULT_FROM_EMAIL=TicketHub <you@gmail.com>

EMAIL_HOST=smtp.gmail.com

SERVER_EMAIL=TicketHub <you@gmail.com>



# --- Celery (optional — leave blank to send email inline without Redis) ---

CELERY_BROKER_URL=redis://redis:6379/0

