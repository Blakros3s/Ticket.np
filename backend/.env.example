SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=tickethub
DB_USER=tickethub
DB_PASSWORD=tickethub_password
DB_HOST=postgres
DB_PORT=5432

FRONTEND_URL=http://localhost:3000

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=43200

# Set to True only in development if public self-registration is required
ALLOW_PUBLIC_REGISTRATION=False

# --- Email (optional — leave blank to disable) ---
# SMTP turns on automatically when all three values below are set.
# Defaults to Gmail (smtp.gmail.com). Use a Google App Password, not your login password.
# EMAIL_PORT=587
# EMAIL_HOST_USER=you@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-app-password
# EMAIL_TLS=true
# DEFAULT_FROM_EMAIL=TicketHub <you@gmail.com>
# EMAIL_HOST=smtp.gmail.com

# --- Celery (optional — leave blank to send email inline without Redis) ---
# Docker dev/prod: use the redis service hostname
CELERY_BROKER_URL=redis://redis:6379/0
# Backend outside Docker only: CELERY_BROKER_URL=redis://localhost:6379/0
